{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Parser-assisted chunking corpus case",
  "type": "object",
  "required": [
    "case_id",
    "corpus",
    "text",
    "document_role",
    "language",
    "source_id",
    "provenance",
    "existing_project_defect",
    "normalization",
    "char_count",
    "related_refs",
    "licensing",
    "notes",
    "frozen"
  ],
  "properties": {
    "case_id": {"type": "string", "pattern": "^[a-z]+-[a-z0-9-]+-[0-9]{4}$"},
    "corpus": {"enum": ["development", "regression", "generalization"]},
    "text": {"type": "string", "minLength": 1},
    "document_role": {"type": "string", "minLength": 1},
    "language": {"type": "string", "minLength": 2},
    "source_id": {"type": "string", "minLength": 1},
    "provenance": {"type": "string", "minLength": 1},
    "existing_project_defect": {"type": "boolean"},
    "normalization": {"type": "string"},
    "char_count": {"type": "integer", "minimum": 1},
    "related_refs": {"type": "array", "items": {"type": "string"}},
    "licensing": {"type": "string", "minLength": 1},
    "notes": {"type": "array", "items": {"type": "string"}},
    "frozen": {"const": true}
  },
  "additionalProperties": false
}
